// Lampu Kendaraan
const int merah = 10;
const int kuning = 9;
const int hijau = 8;

// Penyebrangan kiri
const int merah_kiri = 12;
const int hijau_kiri = 11;

// Penyebrangan kanan
const int merah_kanan = 7;
const int hijau_kanan = 6;

// Pushbutton 
const int tombolKanan = 2; 
const int tombolKiri = 3; 
// Variable flag untuk interrupt
volatile bool adaPermintaanNyebrang = false;

void setup() {
  pinMode(merah, OUTPUT);
  pinMode(kuning, OUTPUT);
  pinMode(hijau, OUTPUT);

  pinMode(merah_kiri, OUTPUT);
  pinMode(hijau_kiri, OUTPUT);
  pinMode(merah_kanan, OUTPUT);
  pinMode(hijau_kanan, OUTPUT);

  // Menggunakan INPUT_PULLUP
  pinMode(tombolKiri, INPUT_PULLUP);
  pinMode(tombolKanan, INPUT_PULLUP);

  // Menghubungkan pin ke fungsi Interrupt (ISR)
  attachInterrupt(digitalPinToInterrupt(tombolKanan), pemicuNyebrang, FALLING);
  attachInterrupt(digitalPinToInterrupt(tombolKiri), pemicuNyebrang, FALLING);
}

void loop() {
  // KONDISI NORMAL: Kendaraan Hijau, Penyebrang Merah
  digitalWrite(hijau, HIGH);
  digitalWrite(kuning, LOW);
  digitalWrite(merah, LOW);

  digitalWrite(merah_kiri, HIGH);
  digitalWrite(hijau_kiri, LOW);
  digitalWrite(merah_kanan, HIGH);
  digitalWrite(hijau_kanan, LOW);

  // Cek apakah ada interupsi dari tombol
  if (adaPermintaanNyebrang) {
    prosesPenyebrangan();
    adaPermintaanNyebrang = false; 
  }
}

// Fungsi yang dijalankan saat tombol ditekan (ISR)
void pemicuNyebrang() {
  adaPermintaanNyebrang = true;
}

// Fungsi urutan lampu penyebrangan
void prosesPenyebrangan() {
  delay(200); // Debounce sederhana

  // Kuning 2 detik
  digitalWrite(hijau, LOW);
  digitalWrite(kuning, HIGH);
  delay(2000);

  // Merah kendaraan + hijau penyebrangan
  digitalWrite(kuning, LOW);
  digitalWrite(merah, HIGH);

  digitalWrite(merah_kiri, LOW);
  digitalWrite(hijau_kiri, HIGH);
  digitalWrite(merah_kanan, LOW);
  digitalWrite(hijau_kanan, HIGH);

  delay(5000); // Waktu nyebrang

  // Transisi kembali ke normal 
  digitalWrite(merah_kiri, HIGH);
  digitalWrite(hijau_kiri, LOW);
  digitalWrite(merah_kanan, HIGH);
  digitalWrite(hijau_kanan, LOW);
  
  digitalWrite(merah, LOW);
  digitalWrite(kuning, HIGH);
  delay(1000);
}
